######## GENERAL IGNORES #######

# ignore logs, OS cache files
*.log
.DS_Store*
ehthumbs.db
Icon?
Thumbs.db

######## GENERAL .NET IGNORES ########

# Ignore binaries in the source
src/*/bin
src/*/obj
src/*/license.xml

# Ignore user-scoped solution and project settings
*.user
*.suo
.vs/

# NuGet packages
packages/*
!packages/repositories.config
Build/*.nupkg

# Docker related files
data/*
deploy/*
.env

# Temporary build folder
_Deploy

# User files
deploy.user.json
!deploy.user.json.sample
UserConfiguration/**/*.config

node_modules/

# Serialization ephemeral files
*.scindex
*.dat
serialization/_out/

# Build output (release artifacts)
_output/*
!_output/.gitkeep
!_output/configs/
!_output/scwdp-template/
!_output/Dockerfile
!_output/.dockerignore

# Jetbrains Rider
.idea

# Claude Code
.claude/settings.local.json
