<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/">
  <sitecore>
    <powershell>
      <authenticationProvider>
        <!-- Reject tokens with lifetime (exp - iat) exceeding 5 minutes -->
        <maxTokenLifetimeSeconds>300</maxTokenLifetimeSeconds>
      </authenticationProvider>
    </powershell>
  </sitecore>
</configuration>
