<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/">
  <sitecore>
    <powershell>
      <authenticationProvider>
        <!-- Reject tokens with lifetime (exp - iat) exceeding 5 minutes -->
        <maxTokenLifetimeSeconds>300</maxTokenLifetimeSeconds>
        <!-- Hardened mode: also reject tokens without iat. Replaces the OOTB
             <requireIat>false</requireIat> via patch:instead. -->
        <requireIat patch:instead="*[local-name()='requireIat']">true</requireIat>
      </authenticationProvider>
    </powershell>
  </sitecore>
</configuration>
