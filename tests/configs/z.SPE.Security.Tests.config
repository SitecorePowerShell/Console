<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/">
  <sitecore>
    <powershell>
      <services>
        <remoting>
          <!-- Enable CLM for security tests -->
          <patch:attribute name="languageMode">ConstrainedLanguage</patch:attribute>
          <!-- Enable command blocklist for security tests -->
          <commandRestrictions mode="blocklist">
            <blockedCommands>
              <command>Invoke-Expression</command>
              <command>Start-Process</command>
            </blockedCommands>
          </commandRestrictions>
        </remoting>
      </services>
      <scopeRestrictions patch:instead="scopeRestrictions"
                        type="Spe.Core.Settings.Authorization.ScriptValidator, Spe" singleInstance="true">
        <!-- Per-scope restrictions for security tests -->
        <read-only name="read-only" hint="raw:AddScopeRestriction">
          <command>Set-Item</command>
          <command>Remove-Item</command>
          <command>New-Item</command>
          <command>Move-Item</command>
          <command>Rename-Item</command>
        </read-only>
        <content-edit name="content-edit" hint="raw:AddScopeRestriction">
          <command>Start-Process</command>
          <command>Invoke-WebRequest</command>
          <command>Invoke-RestMethod</command>
        </content-edit>
      </scopeRestrictions>
    </powershell>
  </sitecore>
</configuration>
