<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/">
  <sitecore>
    <powershell>
      <services>
        <remoting>
          <!-- Assign the read-only profile to remoting for restriction profile tests -->
          <patch:attribute name="profile">read-only</patch:attribute>
        </remoting>
      </services>
    </powershell>
  </sitecore>
</configuration>
