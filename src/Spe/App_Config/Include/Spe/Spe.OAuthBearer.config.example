<!--
    Sitecore PowerShell Extensions - OAuth Bearer Token Authentication

    Opt-in authentication provider that validates externally-issued RS256 /
    RS384 / RS512 / ES256 JWTs via a configured JWKS endpoint. Use for
    XM Cloud style integrations where tokens come from an identity provider
    (Sitecore Identity Server, Auth0, Microsoft Entra ID, Keycloak, Okta)
    rather than being minted client-side with a shared secret.

    Distributed with a .example suffix by default. Copy to
    Spe.OAuthBearer.config (drop the .example) to activate.

    Activation is ADDITIVE: the SharedSecret provider (defined in Spe.config)
    remains registered. The remoting handler dispatches incoming tokens by
    the JWT header "alg" claim - HS* tokens go through SharedSecret;
    RS* / ES* tokens are validated here.

    ==== Multiple IdPs ====

    You can declare more than one <oauthBearer> entry (under different
    element names) to accept tokens from multiple identity providers
    concurrently - e.g. Sitecore Identity Server AND Auth0. The handler
    picks the provider whose <allowedIssuers> list contains the token's
    iss claim, so routing is deterministic rather than last-declared-wins.
    Each entry keeps its own <jwksUri>, <allowedAudiences>, <requiredScopes>,
    and cache. OAuth Client items are already (iss, client_id)-keyed so they
    automatically associate with the correct provider.

    Example:
      <authenticationProviders>
        <oauthBearerIds type="...">
          <jwksUri>https://idp1/.well-known/openid-configuration/jwks</jwksUri>
          <allowedIssuers hint="list"><issuer>https://idp1</issuer></allowedIssuers>
          ...
        </oauthBearerIds>
        <oauthBearerAuth0 type="...">
          <jwksUri>https://tenant.us.auth0.com/.well-known/jwks.json</jwksUri>
          <allowedIssuers hint="list"><issuer>https://tenant.us.auth0.com/</issuer></allowedIssuers>
          ...
        </oauthBearerAuth0>
      </authenticationProviders>

    ==== Required configuration (no defaults) ====

    Three values must be populated for this provider to validate any token.
    Identity comes from the OAuth Client content item matched via
    (issuer, client_id), not from this config - the item's Impersonated User
    field supplies the Sitecore identity.

    ==== Optional overrides ====

    Tunables not listed here - allowedAlgorithms, jwksCacheSeconds,
    maxTokenLifetimeSeconds, clockSkewSeconds, detailedAuthenticationErrors,
    suppressWarnings - default to safe values in the
    OAuthBearerTokenAuthenticationProvider class. Add them under
    <oauthBearer> below if you need to override.

    NOTE: This provider does not support skipping signature validation.
    There is no "skip" flag. Tokens whose signature cannot be verified
    against the configured JWKS are rejected.
-->
<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/"
               xmlns:role="http://www.sitecore.net/xmlconfig/role/"
               xmlns:security="http://www.sitecore.net/xmlconfig/security/">
  <sitecore role:require="Standalone or ContentManagement or XMCloud"
            security:require="Sitecore">
    <powershell>
      <authenticationProviders>
        <oauthBearer type="Spe.Core.Settings.Authorization.OAuthBearerTokenAuthenticationProvider, Spe">
          <!-- The JWKS URL published by the identity provider, typically
               <idp-authority>/.well-known/openid-configuration/jwks.
               Required. Example values:
                 Auth0:           https://<tenant>.auth0.com/.well-known/jwks.json
                 Entra ID:        https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys
                 Sitecore Identity: https://<sitecore-id-host>/.well-known/openid-configuration/jwks
          -->
          <jwksUri></jwksUri>

          <!-- The iss claim(s) issued tokens will carry. Required.
               Example:
                 <issuer>https://auth.sitecorecloud.io/</issuer>
          -->
          <allowedIssuers hint="list">
          </allowedIssuers>

          <!-- The aud claim value(s) SPE will accept. Required.
               Typically the audience identifier you registered with the IdP.
               Some IdPs (like Sitecore Identity Server) automatically include
               an "<authority>/resources" audience alongside your registered
               value; list both if so.
               Example:
                 <audience>spe-remoting</audience>
          -->
          <allowedAudiences hint="list">
          </allowedAudiences>

          <!-- Optional: scope values that every token must carry. When set,
               a token without every required scope is rejected. Leave empty
               to skip scope enforcement.
               Example:
                 <scope>spe.remoting</scope>
          -->
          <requiredScopes hint="list">
          </requiredScopes>

          <!-- Optional: when enabled, the token's typ header MUST be
               "at+jwt" (RFC 9068). Closes the OIDC ID-token-as-access-token
               confusion class on IdPs that distinguish the two.

               Compatibility:
                 Safe to enable: Okta, Duende IdentityServer v5+, Keycloak
                                 20+ (with the at+jwt configuration), Ping.
                 Unsafe to enable: Auth0, Microsoft Entra ID (v1 and v2),
                                   IdentityServer4 / older Sitecore IDS -
                                   these stamp typ=JWT on access tokens.

               Default: false (accepts typ=JWT, typ=at+jwt, or no typ).
          -->
          <requireAccessTokenType>false</requireAccessTokenType>

          <!-- Optional: when enabled and the token's aud claim has more than
               one value, the azp claim must be present and must match the
               resolved client_id used for OAuth Client item lookup
               (OIDC Core 2 Section 3.1.3.7, RFC 7519 Section 4.1.3).
               No effect on single-audience tokens.

               All common IdPs (Auth0, Okta, Entra, Sitecore IDS, Keycloak)
               emit azp on multi-audience tokens, so this is generally safe
               to enable wherever multi-aud tokens are expected.

               Default: false.
          -->
          <requireAzpWhenMultiAudience>false</requireAzpWhenMultiAudience>

          <!-- Optional: replay protection. When enabled, every accepted
               token's (iss, jti) pair is recorded for the remainder of its
               lifetime; a second presentation of the same token returns
               401 with X-SPE-AuthFailureReason: replay. Tokens missing the
               jti claim are also rejected when this is on.

               Cache is process-local. On a multi-node CM cluster, a captured
               token can still be replayed against a sibling node until it
               sees the token. Use a sticky-session load balancer (or accept
               the small replay window between nodes) until distributed
               cache lands.

               Compatibility: every common IdP (Sitecore IDS, Auth0, Okta,
               Entra ID v1/v2, Keycloak, Ping) emits jti by default. Custom
               IdPs that omit jti will fail when this is on.

               Default: off.
          -->
          <jtiReplayCacheEnabled>false</jtiReplayCacheEnabled>

          <!-- Soft cap on the number of (iss, jti) entries kept in memory.
               Expired entries are swept lazily; a sustained over-cap state
               is logged once per minute. At ~150 bytes per entry, the
               default of 10000 costs about 1.5 MB. Bump if your worst-case
               concurrent-token count is higher. -->
          <jtiReplayCacheMaxEntries>10000</jtiReplayCacheMaxEntries>

          <!-- Optional: when true, allows http://localhost, 127.0.0.1, and
               [::1] for the JwksUri (every fetch logs a warn). When false
               (the default), http:// is rejected regardless of host -
               JwksUri must be HTTPS. Never enable this in production; the
               standard dev stack already serves IDS over HTTPS via Traefik.
          -->
          <jwksAllowLoopbackHttp>false</jwksAllowLoopbackHttp>

          <!-- JWKS fetch hardening (always on, no operator knobs):

               1. Response-size cap: 1 MB. A JWKS document larger than this
                  is rejected. A healthy keyset is well under 10 KB.
               2. HTTPS required: http:// JwksUri values are rejected
                  unless jwksAllowLoopbackHttp is set above.
               3. Negative cache: a failed fetch suppresses retries for
                  15 seconds. Prevents repeated 10-second timeouts when
                  the IdP is unreachable.
          -->
        </oauthBearer>
      </authenticationProviders>
    </powershell>
  </sitecore>
</configuration>
